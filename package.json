{
  "name": "workspaceguard-cli",
  "version": "0.1.0",
  "description": "Per-workspace usage metering and quota caps for shared self-hosted AI assistant deployments",
  "keywords": [
    "self-hosted",
    "ai-assistant",
    "usage-metering",
    "quota",
    "billing",
    "multi-tenant",
    "reverse-proxy",
    "odysseus",
    "docker-compose",
    "cli",
    "agent-native"
  ],
  "homepage": "https://github.com/RudrenduPaul/workspaceguard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RudrenduPaul/workspaceguard.git"
  },
  "bugs": {
    "url": "https://github.com/RudrenduPaul/workspaceguard/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "workspaceguard": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "npm run build:test && node --test dist/**/*.test.js",
    "build:test": "tsc -p tsconfig.test.json",
    "dev": "node --experimental-strip-types src/cli/index.ts"
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
